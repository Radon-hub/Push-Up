          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"event_id\": \"{{eventId}}\",\n  \"user_id\": \"{{userId}}\",\n  \"event_name\": \"{{eventName}}\",\n  \"platform\": \"{{platform}}\",\n  \"location\": \"{{location}}\",\n  \"schema_version\": \"1.1.0\",\n  \"app_version\": \"{{appVersion}}\",\n  \"event_time\": {{eventTime}},\n  \"device\": \"{{device}}\",\n  \"properties\": {{properties}}\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://{{Host}}/v1/event",
          "protocol": "http",
          "host": [
            "{{Host}}"
          ],
          "path": [
            "v1",
            "event"
          ]
