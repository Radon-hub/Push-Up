  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          "// Random helpers\r",
          "function randomChoice(arr) { return arr[Math.floor(Math.random() * arr.length)]; }\r",
          "function randomInt(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }\r",
          "function randomBoolean() { return Math.random() < 0.5; }\r",
          "function randomTimestamp() { return Date.now() - randomInt(0, 1000000000); } // within last ~11 days\r",
          "\r",
          "// Event types\r",
          "const events = [\"PRODUCT-PURCHASED\", \"LOGIN\", \"PRODUCT_VIEWED\"];\r",
          "pm.variables.set(\"eventName\", randomChoice(events));\r",
          "pm.variables.set(\"eventId\", \"evt-\" + Math.floor(Math.random()*1000000000));\r",
          "pm.variables.set(\"userId\", \"user_\" + Math.floor(Math.random()*1000));\r",
          "pm.variables.set(\"platform\", randomChoice([\"IOS\",\"ANDROID\",\"WEB\"]));\r",
          "pm.variables.set(\"location\", randomChoice([\"IR\",\"US\"]));\r",
          "pm.variables.set(\"appVersion\", randomChoice([\"1.6.5\",\"1.6.3\",\"1.6.4\"]));\r",
          "pm.variables.set(\"eventTime\", randomTimestamp());\r",
          "pm.variables.set(\"device\", randomChoice([\"Iphone X\",\"Samsung S21\",\"Pixel 5\",\"Ipad Pro\",\"Macbook\"]));\r",
          "\r",
          "// Properties based on event type\r",
          "let props = {};\r",
          "switch(pm.variables.get(\"eventName\")) {\r",
          "    case \"PRODUCT-PURCHASED\":\r",
          "        props = {\r",
          "            \"product_id\": randomInt(10000, 20000),\r",
          "            \"variant_id\": randomInt(100000, 200000),\r",
          "            \"store\": randomInt(100, 200),\r",
          "            \"payment_id\": \"pay_\" + Math.floor(Math.random()*1000000),\r",
          "            \"payment_method\": randomChoice([\"online\",\"cod\"]),\r",
          "            \"warehouse_id\": \"\"+randomInt(1000, 3000),\r",
          "            \"gateway\": randomChoice([\"PAYPAL\",\"STRIPE\",\"ZARINPAL\"]),\r",
          "            \"off\": randomChoice([\"5%\",\"10%\",\"15%\"]),\r",
          "            \"code\": \"CODE\" + randomInt(1000,9999),\r",
          "            \"price\": randomInt(50000, 200000),\r",
          "            \"original_price\": randomInt(200000, 250000),\r",
          "            \"country\": randomChoice([\"TEHRAN\",\"IRAN\"])\r",
          "        };\r",
          "        break;\r",
          "    case \"LOGIN\":\r",
          "        props = {\r",
          "            \"from\": randomChoice([\"login-page\",\"signup-page\",\"profile-page\"]),\r",
          "            \"type\": randomChoice([\"email\",\"phone\"]),\r",
          "            \"status\": randomChoice([\"success\",\"failed\"]),\r",
          "            \"message\": randomChoice([\"successful\",\"incorrect user/pass\"])\r",
          "        };\r",
          "        break;\r",
          "    case \"PRODUCT_VIEWED\":\r",
          "        props = {\r",
          "            \"from\": randomChoice([\"home-page\",\"product-page\",\"banner\"]),\r",
          "            \"product_id\": randomInt(1000000, 2000000),\r",
          "            \"variant_id\": randomInt(1000000, 2000000),\r",
          "            \"vendor_id\": randomInt(10000, 20000),\r",
          "            \"is_liked\": randomBoolean().toString(),\r",
          "            \"in_stock\": randomBoolean().toString()\r",
          "        };\r",
          "        break;\r",
          "}\r",
          "\r",
          "pm.variables.set(\"properties\", JSON.stringify(props));\r",
          ""
        ]
